// TEST/EMU: permisivo (solo para emulador)
// Consent path (PROD rule ready below): patients/{patientId}/consent_status/latest
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // WO-METRICS-00: metrics_events - write only via Cloud Function (admin SDK)
    match /metrics_events/{docId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if true;
    }
  }
}

